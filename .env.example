# Gemini 무료 OCR 키 — 순차적으로 시도 (할당량 초과 시 다음 키로 자동 전환)
# aistudio.google.com 에서 무료로 발급
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_API_KEY_1="SECOND_KEY"
# GEMINI_API_KEY_2="THIRD_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string.
# Example (Neon): postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─────────────────────────────────────────────────────────────────
# Cloudinary — 이슈공유 사진 첨부용 (Render 등 ephemeral 파일시스템 환경 필수)
# Render 배포 시 이 3개를 안 넣으면 로컬 uploads/ 로 fallback 되어
# 재배포·재시작 때마다 첨부한 사진이 전부 사라집니다.
# 무료 25GB: https://cloudinary.com → Dashboard 에서 3개 값 복사
# ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="MY_CLOUD_NAME"
CLOUDINARY_API_KEY="MY_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="MY_CLOUDINARY_API_SECRET"
