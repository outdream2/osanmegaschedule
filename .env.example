# Gemini 무료 OCR 키 — 순차적으로 시도 (할당량 초과 시 다음 키로 자동 전환)
# aistudio.google.com 에서 무료로 발급
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_API_KEY_1="SECOND_KEY"
# GEMINI_API_KEY_2="THIRD_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string.
# Example (Neon): postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname"
