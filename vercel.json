{
  "buildCommand": "npx prisma generate && npx prisma db push && vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "prisma/schema.prisma"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
